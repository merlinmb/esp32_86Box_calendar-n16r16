// secrets.h.example — copy to secrets.h and fill in your values.
// secrets.h is gitignored and will never be committed.
//
// All settings can also be changed at runtime via the web config page
// without reflashing. These are only the compile-time defaults shown
// in the setup form on first boot.

#pragma once

// Calendar server — full URL including timeframe query parameter
#define DEFAULT_CALENDAR_URL  "https://your-calendar-server/jsonCalendar?timeframe=7d"

// MQTT broker for brightness control
#define DEFAULT_MQTT_HOST_VAL  "192.168.1.x"
#define DEFAULT_MQTT_PORT_VAL  1883
#define DEFAULT_MQTT_TOPIC_VAL "cmnd/yourdevice/brightnesspercentage"
